.pio/
.zcode/
/build/
__pycache__/
# Host CMake build trees for every MicroWorld package (one rule covers all).
lib/*/build/
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch

# PlatformIO generates the environment-specific ESP-IDF configuration.
# Keep sdkconfig.defaults as the reproducible source configuration.
sdkconfig.*
!sdkconfig.defaults

# Operating-system metadata
.DS_Store
Thumbs.db
